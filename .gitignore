# Environment variables - never commit these
.env

# Local TLS key material (scripts/generate-dev-tls.sh)
certs/
.venv-barcode/

# Local dev auth session persistence (DEV_PERSIST_AUTH_SESSIONS via dev-up.sh)
.dev-auth-sessions.json

# Node dependencies - reinstalled via npm install
node_modules/

# Mac junk files
.DS_Store

# Logs
*.log
npm-debug.log*

# OCI wallet files (if you ever add wallet-based auth)
wallet/
*.p12
*.sso

# Terraform - secrets and generated state
terraform/terraform.tfvars
terraform/container_env.auto.tfvars
terraform/lb_tls.auto.tfvars
terraform/.terraform/
terraform/.terraform.lock.hcl
terraform/terraform.tfstate
terraform/terraform.tfstate.backup
terraform/terraform.tfstate.*.backup

# Stray Terraform state outside terraform/ (never commit)
scripts/*.tfstate
scripts/*.tfstate.*

# Android POS — Gradle, Studio, and all build outputs (rebuild with ./gradlew)
android-pos/.gradle/
android-pos/**/build/
android-pos/local.properties
android-pos/.idea/
android-pos/*.iml
android-pos/captures/
android-pos/.externalNativeBuild/
android-pos/.cxx/

# iOS admin — Xcode local overrides and user state
ios-admin/Config/Local.xcconfig
ios-admin/**/xcuserdata/
ios-admin/**/DerivedData/

.venv-certbot/

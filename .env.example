# cloud-store-893 environment variables
# Copy this file to .env and fill in your values
# Never commit .env to git

ORDS_BASE_URL=https://YOUR-ADB-HOSTNAME.adb.us-ashburn-1.oraclecloudapps.com/ords/admin
PORT=3000

# Cashier PIN for tablet POS (POST /api/cashier/unlock)
CASHIER_PIN=8930

# Admin PIN for /admin/ (defaults to CASHIER_PIN if unset)
ADMIN_PIN=8930

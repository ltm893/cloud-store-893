# cloud-store-893 environment variables
# Copy this file to .env and fill in your values
# Never commit .env to git

ORDS_BASE_URL=https://YOUR-ADB-HOSTNAME.adb.us-ashburn-1.oraclecloudapps.com/ords/admin
PORT=3000

# Cashier PIN for tablet POS (POST /api/cashier/unlock)
CASHIER_PIN=8930

# Admin PIN for /admin/ (defaults to CASHIER_PIN if unset)
ADMIN_PIN=8930

# Set true when the app is behind HTTPS (OCI LB, Cloudflare Tunnel). Adds Secure on cashier cookie.
# Auto-enabled on OCI when CLOUDFLARE_TUNNEL_TOKEN is set.
# CASHIER_SESSION_SECURE=false

# OCI HTTPS — Load Balancer (POC default). Setup: docs/oci-load-balancer-https.md
# enable_load_balancer in terraform.tfvars + ./scripts/generate-lb-tls.sh
#
# Optional — Cloudflare Tunnel: docs/cloudflare-tunnel.md
# CLOUDFLARE_TUNNEL_TOKEN=eyJh...
# CLOUDFLARE_TUNNEL_HOSTNAME=oci.cloudstore893.com

# Optional: terminate TLS in Node (both paths required). Omit for plain HTTP (default local dev).
# Generate dev certs: ./scripts/generate-dev-tls.sh
# TLS_KEY_PATH=certs/dev-key.pem
# TLS_CERT_PATH=certs/dev-cert.pem
# TLS_CA_PATH=                  # optional CA bundle for client cert verification

# Trust X-Forwarded-* from a reverse proxy / load balancer. Auto-enabled when
# CASHIER_SESSION_SECURE=true or TLS_KEY_PATH+TLS_CERT_PATH are set. Override:
# TRUST_PROXY=true

# Set automatically by scripts/dev-up.sh — keeps PIN sessions across node --watch restarts.
# DEV_PERSIST_AUTH_SESSIONS=true

# OCI operator shell vars (not app env — set in ~/.zshrc). See docs/oci-network-recovery.md
# export CLOUD_STORE_OCID=$(cd terraform && terraform output -raw container_instance_ocid)
# export CLOUD_STORE_RESERVED_PUBLIC_IP_OCID=ocid1.publicip.oc1.iad....

# Phase 2 IdP — after Level 1 app recreate: docs/idp-level1-reset.md
# Local dev: set APP_PUBLIC_URL. OCI: use APP_PUBLIC_URL_FROM_REQUEST=true and browse via oci.cloudstore893.com (see docs/oci-network-recovery.md).
# APP_PUBLIC_URL=http://127.0.0.1:3000
# APP_PUBLIC_URL_FROM_REQUEST=true
# IDP_POS_ISSUER=https://idcs-....identity.oraclecloud.com
# IDP_POS_CLIENT_ID=
# IDP_POS_CLIENT_SECRET=
# IDP_POS_REDIRECT_URI=http://150.136.37.236:3000/oauth/callback
# IDP_ADMIN_ISSUER=https://idcs-....identity.oraclecloud.com
# IDP_ADMIN_CLIENT_ID=
# IDP_ADMIN_CLIENT_SECRET=
# IDP_ADMIN_REDIRECT_URI=http://150.136.37.236:3000/oauth/admin/callback
# IDP_ALLOW_PIN=true

# Cash drawer — expected opening float. Unset = credit-only store (no cash pay). Design: docs/cash-till-opening-and-close.md
# OPENING_CASH_FLOAT=200.00

# POS tax / fee rates (decimal fractions). Must match tablet/ios-pos BuildConfig / xcconfig.
# POS_SALES_FEE_RATE=0.0
# POS_TAX_RATE=0.06

# Model B — supervisor approval after IdP cashier login (feature/cashier-supervisor-approval)
# CASHIER_SUPERVISOR_APPROVAL=false
# CASHIER_APPROVAL_TTL_SEC=300
# IDP_POS_CASHIER_GROUP=store-cashiers
# IDP_SUPERVISOR_GROUP=store-supervisors
# Local dev only: treat admin PIN login as supervisor when IdP groups are not configured yet
# CASHIER_SUPERVISOR_PIN_IS_SUPERVISOR=false

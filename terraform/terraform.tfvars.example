# Copy this file to terraform.tfvars and fill in your values.
# ⚠️  Never commit terraform.tfvars to git — it contains secrets.

# ── OCI Auth ──────────────────────────────────────────────────────────────────
# OCI Console → Profile → My Profile → API Keys → Add API Key
# The console shows tenancy_ocid, user_ocid, fingerprint after key creation.

tenancy_ocid     = "ocid1.tenancy.oc1..aaaa..."
user_ocid        = "ocid1.user.oc1..aaaa..."
fingerprint      = "xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx"
private_key_path = "~/.oci/oci_api_key.pem"
region           = "us-ashburn-1"

# ── Project ───────────────────────────────────────────────────────────────────
# object_storage_namespace: OCI Console → Governance → Tenancy Details
object_storage_namespace = "your_namespace_here"
ocir_region_key          = "iad"   # iad = us-ashburn-1
# project_name — single compartment name + OCIR repo + display names (default: cloud-store).
# Override only if you intentionally use a different compartment name everywhere.
# project_name = "cloud-store"

# ── Database ──────────────────────────────────────────────────────────────────
# Password rules: min 12 chars, at least one uppercase, lowercase, number, special char
adb_admin_password = "YourStr0ng!Password"

# ── App PINs (container env — tablet login + admin UI) ───────────────────────
# cashier_pin = "8930"
# admin_pin   = "8930"   # optional; defaults to cashier_pin when empty
# cashier_session_secure = true   # use when HTTPS terminates in front of the app (auto when tunnel token set)
#
# HTTPS — OCI Load Balancer (required for POC when LB is mandated). See docs/oci-load-balancer-https.md
# enable_load_balancer = true
# lb_public_hostname   = "oci.cloudstore893.com"
# TLS PEMs in lb_tls.auto.tfvars — run: ./scripts/generate-lb-tls.sh oci.cloudstore893.com
#
# Optional alternative — Cloudflare Tunnel (docs/cloudflare-tunnel.md)
# cloudflare_tunnel_token    = "eyJh..."
# cloudflare_tunnel_hostname = "oci.cloudstore893.com"

# ── Network lockdown (optional) ─────────────────────────────────────────────
# ingress_allowed_cidrs = ["203.0.113.50/32"]   # shop IP; default ["0.0.0.0/0"]
# allow_ssh_ingress     = false

# ── IdP + Model B (optional — or use container_env.auto.tfvars) ─────────────
# From repo root: ./scripts/oci/sync-container-env-to-terraform.sh
# generates terraform/container_env.auto.tfvars from .env, then terraform apply.
#
# app_public_url = "http://150.136.208.81:3000"
# idp_pos_issuer = "https://idcs-....identity.oraclecloud.com"
# idp_pos_client_id = "..."
# idp_pos_client_secret = "..."
# cashier_supervisor_approval = true
# cashier_supervisor_pin_is_supervisor = true
